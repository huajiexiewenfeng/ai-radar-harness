# Optional LLM scoring key. Keep `llm.provider: none` to run without an LLM.
AI_RADAR_LLM_KEY=

# Optional direct X API fallback.
# The current core CLI reads the bearer token from this env var.
X_API_BEARER_TOKEN=

# Optional X API key metadata for your own wrappers or hosted adapters.
# The core CLI does not read this value directly yet.
AI_RADAR_X_API_KEY=

# Optional X MCP server credentials.
# These are for the MCP server / agent connector layer, not for the harness
# runtime itself. Reference these env vars from Codex, Claude, Cursor, or your
# own MCP server config instead of committing secrets to YAML.
X_MCP_CLIENT_ID=
X_MCP_CLIENT_SECRET=
